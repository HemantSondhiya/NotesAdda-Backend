# ============================================
# NotsHub - JWT Authentication Configuration
# EXAMPLE FILE - Copy to .env and update values
# ============================================
# IMPORTANT: Never commit .env file to version control!
# Add .env to .gitignore before committing

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080

# ============================================
# Database Configuration
# ============================================
DB_URL=jdbc:mysql://localhost:3306/notshub
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ============================================
# JWT Configuration - SECURITY CRITICAL
# ============================================
# MUST: Generate a strong secret key (minimum 32 characters)
#
# Generate using these commands:
# Linux/Mac:
#   openssl rand -base64 32
#
# PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
#
# Or use online generator: https://1password.com/password-generator/
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_production_abc123xyz789

# Token expiration time in milliseconds
# 86400000 = 1 day
# 604800000 = 7 days
JWT_EXPIRATION=86400000

# ============================================
# HTTPS/SSL Configuration
# ============================================
# MUST enable for production: true
# Development only: false
SSL_ENABLED=false

# Path to your keystore file (PKCS12 format)
# Generate with: keytool -genkeypair -alias tomcat -keyalg RSA -keysize 2048 -keystore keystore.p12 -storetype PKCS12
# Example: /path/to/keystore.p12 or C:\\keystore.p12 (Windows)
SSL_KEYSTORE_PATH=

# Password for your keystore file
SSL_KEYSTORE_PASSWORD=your_keystore_password_here

# ============================================
# Frontend Configuration
# ============================================
# Update with your actual frontend URL in production
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173/

# ============================================
# JWT Cookie Configuration
# ============================================
JWT_COOKIE_NAME=springBootEcom

# HttpOnly flag: true prevents JavaScript access (XSS protection)
# Must be true in production
JWT_COOKIE_HTTP_ONLY=true

# Secure flag: true means HTTPS only
# Must be true in production (requires SSL_ENABLED=true)
JWT_COOKIE_SECURE=false

# ============================================
# Application Environment
# ============================================
# Options: development, staging, production
ENVIRONMENT=development

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# Log file path
LOG_FILE_PATH=logs/application.log

# Max log file size before rotation
LOG_MAX_SIZE=10MB

# Number of log files to keep
LOG_MAX_HISTORY=30

