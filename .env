# ============================================
# NotsHub - JWT Authentication Configuration
# ============================================
# IMPORTANT: Never commit this file to version control!
# Add .env to .gitignore

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=9091

# ============================================
# Database Configuration
# SECURITY: Use environment variables for sensitive data
# ============================================
DB_URL=jdbc:mysql://localhost:3306/noteshub
DB_USERNAME=root
DB_PASSWORD=628056@Hk

# ============================================
# JWT Configuration - SECURITY CRITICAL
# ============================================
# MUST: Generate a strong secret key (minimum 32 characters)
# Command: openssl rand -base64 32
JWT_SECRET=mySecretKey123912738aopsgjnspkmndfsopkvajoirjg94gf2opfng2moknm
JWT_EXPIRATION=86400000

# ============================================
# JWT Cookie Configuration
# ============================================
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SECURE=true

# ============================================
# HTTPS/SSL Configuration
# ============================================
# Set to true for production ONLY when keystore is available
SSL_ENABLED=false
SSL_KEYSTORE_PATH=
SSL_KEYSTORE_PASSWORD=

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost:5173/

# ============================================
# Logging Configuration
# ============================================
# Production levels: WARN, INFO
# Development levels: DEBUG, TRACE
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_FILE_PATH=logs/application.log

# ============================================
# Hibernate Configuration
# ============================================
# validate - only validate schema without changes
# update - create schema if needed (development only)
# create - always create new schema (test only)
# create-drop - create and drop on shutdown (test only)
HIBERNATE_DDL=update

# ============================================
# Application Environment
# ============================================
ENVIRONMENT=production
