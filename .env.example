# ============================================
# NotsHub - JWT Authentication Configuration
# EXAMPLE FILE - Copy to .env and update values
# ============================================
# IMPORTANT: Never commit .env file to version control!
# Add .env to .gitignore before committing

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=5000

# ============================================
# Database Configuration
# ============================================
DB_URL=jdbc:mysql://localhost:3306/notshub
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# ============================================
# JWT Configuration - SECURITY CRITICAL
# ============================================
# MUST: Generate a strong secret key (minimum 32 characters)
#
# Generate using these commands:
# Linux/Mac:
#   openssl rand -base64 32
#
# PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))
#
# Or use online generator: https://1password.com/password-generator/
JWT_SECRET=8uW8D3sfq4Vb8YwqbY0xjvJ6a4P4L4r1sW4A7l9q6Gs=

# Token expiration time in milliseconds
# 86400000 = 1 day
# 604800000 = 7 days
JWT_EXPIRATION=86400000

# ============================================
# HTTPS/SSL Configuration
# ============================================
# MUST enable for production: true
# Development only: false
SSL_ENABLED=false

# Path to your keystore file (PKCS12 format)
# Generate with: keytool -genkeypair -alias tomcat -keyalg RSA -keysize 2048 -keystore keystore.p12 -storetype PKCS12
# Example: /path/to/keystore.p12 or C:\\keystore.p12 (Windows)
SSL_KEYSTORE_PATH=

# Password for your keystore file
SSL_KEYSTORE_PASSWORD=your_keystore_password_here

# ============================================
# Frontend Configuration
# ============================================
# Update with your actual frontend URL in production
# Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
FRONTEND_ALLOWED_ORIGINS=

# ============================================
# JWT Cookie Configuration
# ============================================
JWT_COOKIE_NAME=springBootEcom

# HttpOnly flag: true prevents JavaScript access (XSS protection)
# Must be true in production
JWT_COOKIE_HTTP_ONLY=true

# Secure flag: true means HTTPS only
# Must be true in production (requires SSL_ENABLED=true)
JWT_COOKIE_SECURE=true

# ============================================
# Application Environment
# ============================================
# Options: development, staging, production
ENVIRONMENT=production

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL_ROOT=WARN
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN

# Log file path
LOG_FILE_PATH=logs/application.log

# Max log file size before rotation
LOG_MAX_SIZE=10MB

# Number of log files to keep
LOG_MAX_HISTORY=30

# ============================================
# Development-only Endpoint Exposure
# ============================================
# false in production. Set true only for local dev/testing.
EXPOSE_DEV_ENDPOINTS=false

# Trust X-Forwarded-For headers from your reverse proxy (true only behind trusted proxy)
TRUST_FORWARD_HEADERS=true
RATE_LIMIT_ENABLED=true

# ============================================
# AWS S3 Configuration
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-private-notes-bucket
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_PRESIGNED_EXPIRY_MINUTES=5

# ============================================
# Email OTP Configuration
# ============================================
# Set to false in production to send real OTP emails.
EMAIL_OTP_LOG_ONLY=false
EMAIL_OTP_EXPIRY_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60

# SMTP Provider Settings (required when EMAIL_OTP_LOG_ONLY=false)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_app_password
MAIL_FROM=no-reply@notshub.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

